# ═══════════════════════════════════════════════════════════════════════════
# studyledger.in — environment
#
# Every variable the code reads is listed here. If you add a new
# process.env.* reference, add it here in the same commit. This file drifting
# out of date is what caused Stripe and push to ship without their env vars.
#
# Copy to .env.local for local dev. Production values live in Vercel →
# Settings → Environment Variables (this file is NOT the source of truth
# for prod).
# ═══════════════════════════════════════════════════════════════════════════

# ── Core: the app will not boot without these ──────────────────────────────
# Anthropic — powers /api/ai (every AI tool). https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# Supabase — auth + database. Project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Service role bypasses RLS. Server-only — never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Stripe: payments. Missing these = checkout 503s ────────────────────────
# Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
# Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
# Products → your product → price ID. All four are required; a missing one
# makes that plan return "This plan is not configured yet."
# Prices must match the numbers hardcoded in components/ui/pricing-cards.tsx.
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_MAX_MONTHLY=price_...
STRIPE_PRICE_MAX_YEARLY=price_...

# ── Cron: FAIL-CLOSED. If unset, every cron job returns 401 and silently ───
# ── stops running (weekly reports, risk alerts, notifications, job queue).  ─
# Any long random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# ── Push notifications: generate with `npx web-push generate-vapid-keys` ───
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@studyledger.in

# ── Email (Resend) — welcome, weekly report, parent digest ─────────────────
RESEND_API_KEY=re_...

# ── Auth: Google OAuth ─────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Admin dashboard ────────────────────────────────────────────────────────
ADMIN_KEY=

# ── Analytics (PostHog) ────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Optional ───────────────────────────────────────────────────────────────
# Defaults to https://studyledger.in. Set for local/preview so Stripe
# redirects and email links point at the right origin.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Tier gates auto-enable on 2026-09-08. "on"/"off" overrides that date.
NEXT_PUBLIC_TIER_ENFORCEMENT=
# Sentry source-map upload at build time (not needed for local dev).
SENTRY_ORG=
SENTRY_PROJECT=
